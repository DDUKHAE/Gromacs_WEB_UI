; npt.mdp - constant pressure equilibration
integrator               = md
nsteps                   = {nsteps}
dt                       = {dt}
nstxout                  = 0
nstvout                  = 0
nstenergy                = 500
nstlog                   = 500
nstxout-compressed       = 500
continuation             = yes
constraint_algorithm     = {constraint_algorithm}
constraints              = {constraints}
cutoff-scheme            = Verlet
ns_type                  = grid
nstlist                  = 10
rcoulomb                 = {rcoulomb}
rvdw                     = {rvdw}
coulombtype              = {coulombtype}
pme_order                = {pme_order}
fourierspacing           = {fourierspacing}
tcoupl                   = {tcoupl}
tc-grps                  = {tc_grps}
tau_t                    = {tau_t_list}
ref_t                    = {ref_t_list}
pcoupl                   = {pcoupl}
pcoupltype               = isotropic
tau_p                    = {tau_p}
ref_p                    = {ref_p}
compressibility          = 4.5e-5
refcoord_scaling         = com
pbc                      = xyz
DispCorr                 = EnerPres
gen_vel                  = no
